# Optional. Only used if `gh auth token` is unavailable.
# GITHUB_TOKEN=ghp_xxx

# Used by `gt distill` (P2). Set one of these; the factory picks Claude first,
# else Gemini, else falls back to local Ollama.
# ANTHROPIC_API_KEY=sk-ant-xxx
# GEMINI_API_KEY=...           # from https://aistudio.google.com
